{
  "_meta": {
    "version": "1.0.0",
    "project": "MH-Cortex",
    "note": "Schema canônico para todas as entidades do acervo. Arquivos _raw preservados intactos. Arquivos _normalized seguem este schema."
  },

  "weapon": {
    "_description": "Arma de qualquer jogo, qualquer tipo",
    "id":               "string — identificador único dentro do jogo (prefixo: mhfu_, mhgu_, etc.)",
    "game":             "string — ex: 'mhfu', 'mhgu', 'world', 'rise', 'mh3tri', 'mhp3rd', 'mhdos'",
    "name":             "string",
    "name_ja":          "string | null",
    "weapon_type":      "string — ex: 'Great Sword', 'Switch Axe', 'Bow'",
    "rarity":           "int | null",
    "slots":            "int — número de slots (0-3)",

    "damage": {
      "display_raw":    "int — o que o jogo mostra na tela (bloated)",
      "true_raw":       "float — display_raw / class_coefficient",
      "class_coefficient": "float — multiplicador de classe da arma",
      "affinity":       "int — % de affinity (-100 a +100)",
      "element_type":   "string | null — 'fire','water','thunder','ice','dragon','poison','paralysis','sleep','blast'",
      "element_display":"int | null — valor de elemento como mostrado no jogo",
      "element_true":   "float | null — element_display / 10 (exceto Rise/Wilds que já mostram true)",
      "element_hidden": "bool — true = elemento dorme (awakened)",
      "element_notes":  "string | null — ex: 'Rise/Wilds display is already true value'"
    },

    "sharpness": {
      "levels":         "array[int] — barras de cada cor [red,orange,yellow,green,blue,white,purple]. 0 = ausente",
      "max_levels":     "array[int] | null — com Sharpness+1/Handicraft (null se não aplicável)",
      "note":           "string | null"
    },

    "craft": {
      "buy_price":      "int | null",
      "sell_price":     "int | null",
      "create_materials": "array[{item_id, item_name, amount}]",
      "upgrade_from":   "string | null — id da arma pai na árvore",
      "upgrade_materials": "array[{item_id, item_name, amount}]"
    },

    "type_specific":    "object | null — campos específicos do tipo: {phial, shelling, notes, kinsect_bonus, etc.}",
    "source_file":      "string — arquivo _raw de origem"
  },

  "damage_coefficients": {
    "_description": "Tabela de class_coefficient por jogo e tipo de arma",
    "_source": "GameFAQs damage formula FAQs + fandom wiki + community research",

    "gen1_2_psp": {
      "_applies_to": ["mhfu", "mhf2", "mhf1", "mh1", "mh2", "mhdos", "mhg"],
      "_note": "Portable Team (PSP/PS2 gen1-2): geralmente mostram true raw sem bloat. MHFU é exceção rara que usa bloat.",
      "Great Sword":        4.8,
      "Long Sword":         4.8,
      "Sword and Shield":   1.4,
      "Dual Blades":        1.4,
      "Hammer":             5.2,
      "Hunting Horn":       4.2,
      "Lance":              2.3,
      "Gunlance":           2.3,
      "Bow":                1.2,
      "Light Bowgun":       1.3,
      "Heavy Bowgun":       1.5,
      "_element_divisor":   10
    },

    "mh3tri_mh3u": {
      "_applies_to": ["mh3tri", "mh3u"],
      "_note": "MH3/Tri mesmos coeficientes. Switch Axe adicionado.",
      "Great Sword":        4.8,
      "Long Sword":         4.8,
      "Sword and Shield":   1.4,
      "Hammer":             5.2,
      "Hunting Horn":       4.2,
      "Lance":              2.3,
      "Gunlance":           2.3,
      "Switch Axe":         5.4,
      "Bow":                1.2,
      "Light Bowgun":       1.3,
      "Heavy Bowgun":       1.5,
      "_element_divisor":   10
    },

    "mh4_mh4u_mhgen_mhgu": {
      "_applies_to": ["mhgu", "mhgen", "mh4u", "mh4"],
      "_note": "Gen 4+. Insect Glaive e Charge Blade adicionados.",
      "Great Sword":        4.8,
      "Long Sword":         3.3,
      "Sword and Shield":   1.4,
      "Dual Blades":        1.4,
      "Hammer":             5.2,
      "Hunting Horn":       4.2,
      "Lance":              2.3,
      "Gunlance":           2.3,
      "Switch Axe":         5.4,
      "Charge Blade":       3.6,
      "Insect Glaive":      3.1,
      "Bow":                1.2,
      "Light Bowgun":       1.3,
      "Heavy Bowgun":       1.5,
      "_element_divisor":   10
    },

    "world_iceborne": {
      "_applies_to": ["world"],
      "_note": "MHWorld/Iceborne. Mesma tabela da gen4.",
      "Great Sword":        4.8,
      "Long Sword":         3.3,
      "Sword and Shield":   1.4,
      "Dual Blades":        1.4,
      "Hammer":             5.2,
      "Hunting Horn":       4.2,
      "Lance":              2.3,
      "Gunlance":           2.3,
      "Switch Axe":         3.5,
      "Charge Blade":       3.6,
      "Insect Glaive":      3.1,
      "Bow":                1.2,
      "Light Bowgun":       1.3,
      "Heavy Bowgun":       1.5,
      "_element_divisor":   10
    },

    "rise_sunbreak": {
      "_applies_to": ["rise"],
      "_note": "Rise/Sunbreak. RAW ainda usa coeficiente. ELEMENTO já é true value (não divide por 10).",
      "Great Sword":        4.8,
      "Long Sword":         3.3,
      "Sword and Shield":   1.4,
      "Dual Blades":        1.4,
      "Hammer":             5.2,
      "Hunting Horn":       4.2,
      "Lance":              2.3,
      "Gunlance":           2.3,
      "Switch Axe":         3.5,
      "Charge Blade":       3.6,
      "Insect Glaive":      3.1,
      "Bow":                1.2,
      "Light Bowgun":       1.3,
      "Heavy Bowgun":       1.5,
      "_element_divisor":   1,
      "_element_note":      "Rise mostra true element diretamente. Sem divisão."
    },

    "wilds": {
      "_applies_to": ["wilds"],
      "_note": "Wilds tem toggle in-game 'Display Without Coefficient'. Schema salva ambos.",
      "Great Sword":        4.8,
      "Long Sword":         3.3,
      "Sword and Shield":   1.4,
      "Dual Blades":        1.4,
      "Hammer":             5.2,
      "Hunting Horn":       4.2,
      "Lance":              2.3,
      "Gunlance":           2.3,
      "Switch Axe":         3.5,
      "Charge Blade":       3.6,
      "Insect Glaive":      3.1,
      "Bow":                1.2,
      "Light Bowgun":       1.3,
      "Heavy Bowgun":       1.5,
      "_element_divisor":   1,
      "_element_note":      "Wilds: RAW usa coeficiente. Elemento já é true (igual Rise)."
    }
  },

  "sharpness_multipliers": {
    "_description": "Multiplicador de dano RAW e Elemental por nível de sharpness",
    "_source": "MHFU GameFAQs FAQ + fandom wiki + Game8 Rise sharpness guide",
    "_note": "Aplicar sobre true_raw para obter effective_raw antes de hitzone",

    "gen1_to_world": {
      "_applies_to": ["mhfu","mhf2","mhf1","mh1","mh2","mhdos","mhg","mh3tri","mh3u","mhgu","mhgen","mh4u","mh4","world"],
      "red":    { "raw": 0.50, "element": 0.25 },
      "orange": { "raw": 0.75, "element": 0.50 },
      "yellow": { "raw": 1.00, "element": 0.75 },
      "green":  { "raw": 1.05, "element": 1.00 },
      "blue":   { "raw": 1.20, "element": 1.0625 },
      "white":  { "raw": 1.32, "element": 1.15 },
      "purple": { "raw": 1.45, "element": 1.25 }
    },

    "rise_sunbreak": {
      "_applies_to": ["rise"],
      "_note": "Rise/Sunbreak ajustou levemente os multiplicadores",
      "red":    { "raw": 0.50, "element": 0.25 },
      "orange": { "raw": 0.75, "element": 0.50 },
      "yellow": { "raw": 1.00, "element": 0.75 },
      "green":  { "raw": 1.05, "element": 1.00 },
      "blue":   { "raw": 1.20, "element": 1.05 },
      "white":  { "raw": 1.32, "element": 1.15 },
      "purple": { "raw": 1.39, "element": 1.25 }
    },

    "wilds": {
      "_applies_to": ["wilds"],
      "_note": "Wilds — valores confirmados pela comunidade (similar Rise)",
      "red":    { "raw": 0.50, "element": 0.25 },
      "orange": { "raw": 0.75, "element": 0.50 },
      "yellow": { "raw": 1.00, "element": 0.75 },
      "green":  { "raw": 1.05, "element": 1.00 },
      "blue":   { "raw": 1.20, "element": 1.05 },
      "white":  { "raw": 1.32, "element": 1.15 },
      "purple": { "raw": 1.39, "element": 1.25 }
    }
  },

  "armor_piece": {
    "id":               "string",
    "game":             "string",
    "name":             "string",
    "name_ja":          "string | null",
    "part":             "string — 'head','chest','arms','waist','legs'",
    "type":             "string — 'blademaster','gunner','both'",
    "rarity":           "int | null",
    "gender":           "string | null — 'male','female','both'",
    "defense":          "{ base: int, max: int | null }",
    "resistances":      "{ fire: int, water: int, thunder: int, ice: int, dragon: int }",
    "slots":            "array[int] — ex: [2,1,0] = slot2, slot1, vazio",
    "skills":           "array[{ skill_id: string, skill_name: string, points: int }]",
    "craft":            "{ buy_price: int|null, create_materials: array[{item_id,item_name,amount}] }",
    "source_file":      "string"
  },

  "skill": {
    "id":               "string",
    "game":             "string",
    "name":             "string",
    "name_ja":          "string | null",
    "tree_id":          "string | null — id da skill tree (pre-World)",
    "tree_name":        "string | null",
    "levels":           "array[{ level: int, name: string | null, description: string, points_required: int | null }]",
    "max_level":        "int",
    "source_file":      "string"
  },

  "monster": {
    "id":               "string",
    "game":             "string",
    "name":             "string",
    "name_ja":          "string | null",
    "species":          "string — 'Flying Wyvern','Elder Dragon','Fanged Beast', etc.",
    "is_large":         "bool",
    "elements":         "array[string] — elementos de ataque do monstro",
    "ailments":         "array[string]",
    "weaknesses":       "array[{ element: string, rating: int }] — 1-3 estrelas",
    "hitzones":         "array[{ part: string, slash: int, blunt: int, shot: int, fire: int, water: int, thunder: int, ice: int, dragon: int }] | null",
    "locations":        "array[string]",
    "games":            "array[string] — jogos onde aparece",
    "source_file":      "string"
  },

  "item": {
    "id":               "string",
    "game":             "string",
    "name":             "string",
    "name_ja":          "string | null",
    "description":      "string | null",
    "category":         "string | null — 'material','consumable','ammo','trap','misc'",
    "rarity":           "int | null",
    "carry_max":        "int | null",
    "buy_price":        "int | null",
    "sell_price":       "int | null",
    "source_file":      "string"
  },

  "quest": {
    "id":               "string",
    "game":             "string",
    "name":             "string",
    "name_ja":          "string | null",
    "hub":              "string — 'village','city','hub','arena'",
    "rank":             "string — 'LR','HR','MR','G'",
    "stars":            "string — '1★' até '8★' ou 'G1' etc.",
    "objective_type":   "string — 'hunt','capture','slay','gather','deliver','escort'",
    "targets":          "array[{ monster_id: string, monster_name: string, count: int }]",
    "contract_fee":     "int | null",
    "time_limit":       "int | null — minutos",
    "rewards":          "array[{ item_id: string, item_name: string, amount: int, chance: float }] | null",
    "source_file":      "string"
  },

  "decoration": {
    "id":               "string",
    "game":             "string",
    "name":             "string",
    "name_ja":          "string | null",
    "slot_size":        "int — 1, 2 ou 3",
    "skills":           "array[{ skill_id: string, skill_name: string, points: int }]",
    "craft":            "{ materials: array[{item_id,item_name,amount}] } | null",
    "source_file":      "string"
  },

  "charm": {
    "id":               "string",
    "game":             "string",
    "name":             "string | null",
    "skills":           "array[{ skill_id: string, skill_name: string, points: int }]",
    "slots":            "int",
    "source_file":      "string"
  }
}
